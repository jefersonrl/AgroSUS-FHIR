       fhir:PlanDefinition.action.title [ fhir:value "Gatilho adicional — admissional, retorno de afastamento > 30 dias, mudança de função, sintomático, após surto/bloqueio de aplicação, ou retestagem pós-resultado alterado" ]
     ]
  ], [
     fhir:index 3 ;
     fhir:PlanDefinition.action.title [ fhir:value "Conduta frente a resultado alterado" ] ;
     fhir:PlanDefinition.action.description [ fhir:value "Afastar do contato com o agrotóxico por 30 dias; encaminhar para avaliação clínica e laboratorial; repetir exame em 30 dias; investigar outras causas antes de concluir pela exposição ocupacional. Registrado via CarePlan/AgroSUSPlanoAcompanhamento." ] ;
     fhir:PlanDefinition.action.condition [
