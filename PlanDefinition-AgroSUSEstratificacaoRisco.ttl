     ]
  ] ;
  fhir:PlanDefinition.status [ fhir:value "active"] ;
  fhir:PlanDefinition.experimental [ fhir:value "true"^^xsd:boolean] ;
  fhir:PlanDefinition.date [ fhir:value "2026-07-21T16:50:13+00:00"^^xsd:dateTime] ;
  fhir:PlanDefinition.publisher [ fhir:value "Fatec Ferraz de Vasconcelos"] ;
  fhir:PlanDefinition.contact [
     fhir:index 0 ;
     fhir:ContactDetail.name [ fhir:value "Fatec Ferraz de Vasconcelos" ] ;
     fhir:ContactDetail.telecom [
       fhir:index 0 ;
       fhir:ContactPoint.system [ fhir:value "url" ] ;
       fhir:ContactPoint.value [ fhir:value "https://www.fatecferraz.edu.br" ]
     ]
  ] ;
  fhir:PlanDefinition.description [ fhir:value "Workflow de suporte à decisão: classifica o resultado da colinesterase, define a periodicidade do monitoramento biológico e avalia gatilhos de alerta independentes (sintomas, produto sem EPI adequado, histórico de intoxicação). Apoia — não substitui — o julgamento clínico do profissional assistencial da UBS."] ;
  fhir:PlanDefinition.jurisdiction [
     fhir:index 0 ;
     fhir:CodeableConcept.coding [
       fhir:index 0 ;
       fhir:Coding.system [ fhir:value "urn:iso:std:iso:3166" ] ;
       fhir:Coding.code [ fhir:value "BR" ] ;
       fhir:Coding.display [ fhir:value "Brazil" ]
     ]
  ] ;
  fhir:PlanDefinition.library [
     fhir:value "https://jefersonrl.github.io/AgroSUS-FHIR/Library/AgroSUSIntoxicacaoLogic" ;
     fhir:index 0 ;
     fhir:link <https://jefersonrl.github.io/AgroSUS-FHIR/Library/AgroSUSIntoxicacaoLogic>
  ] ;
  fhir:PlanDefinition.action [
     fhir:index 0 ;
     fhir:PlanDefinition.action.title [ fhir:value "Obter valor basal e resultado da colinesterase" ] ;
     fhir:PlanDefinition.action.description [ fhir:value "Determinar a atividade basal (pré-ocupacional) na admissão; calcular o percentual de inibição do resultado atual em relação ao basal. Registrado via ServiceRequest/AgroSUSSolicitacaoExame e Observation/AgroSUSResultadoLaboratorial." ]
  ], [
     fhir:index 1 ;
     fhir:PlanDefinition.action.title [ fhir:value "Classificar o resultado da colinesterase" ] ;
     fhir:PlanDefinition.action.description [ fhir:value "Classifica o percentual de inibição conforme o tipo de amostra. REVISAR fonte: NR-7 Quadro I; Nota Informativa 16/2019." ] ;
     fhir:PlanDefinition.action.action [
       fhir:index 0 ;
       fhir:PlanDefinition.action.title [ fhir:value "Normal — colinesterase plasmática (inibição <= 50%) ou sangue total (inibição <= 25%)" ] ;
       fhir:PlanDefinition.action.condition [
         fhir:index 0 ;
         fhir:PlanDefinition.action.condition.kind [ fhir:value "applicability" ] ;
         fhir:PlanDefinition.action.condition.expression [
           fhir:Expression.language [ fhir:value "text/fhirpath" ] ;
           fhir:Expression.expression [ fhir:value "%inibicaoPlasmatica <= 50 or %inibicaoSangueTotal <= 25" ]
         ]
       ]
     ], [
       fhir:index 1 ;
       fhir:PlanDefinition.action.title [ fhir:value "Precaução — redução de 20% a 50%/25% (não atinge o IBMP)" ] ;
       fhir:PlanDefinition.action.condition [
         fhir:index 0 ;
         fhir:PlanDefinition.action.condition.kind [ fhir:value "applicability" ] ;
         fhir:PlanDefinition.action.condition.expression [
           fhir:Expression.language [ fhir:value "text/fhirpath" ] ;
           fhir:Expression.expression [ fhir:value "%inibicaoPlasmatica >= 20 and %inibicaoPlasmatica <= 50" ]
         ]
       ]
     ], [
       fhir:index 2 ;
       fhir:PlanDefinition.action.title [ fhir:value "Alterado — excede o Índice Biológico Máximo Permitido (IBMP)" ] ;
       fhir:PlanDefinition.action.condition [
         fhir:index 0 ;
         fhir:PlanDefinition.action.condition.kind [ fhir:value "applicability" ] ;
         fhir:PlanDefinition.action.condition.expression [
           fhir:Expression.language [ fhir:value "text/fhirpath" ] ;
           fhir:Expression.expression [ fhir:value "%inibicaoPlasmatica > 50 or %inibicaoSangueTotal > 25" ]
         ]
       ]
     ]
  ], [
     fhir:index 2 ;
     fhir:PlanDefinition.action.title [ fhir:value "Definir periodicidade do monitoramento biológico" ] ;
     fhir:PlanDefinition.action.description [ fhir:value "Periodicidade mínima semestral (NR-7 7.4.2.1), com gatilhos adicionais independentes da rotina." ] ;
     fhir:PlanDefinition.action.action [
       fhir:index 0 ;
       fhir:PlanDefinition.action.title [ fhir:value "Rotina — no mínimo a cada 6 meses" ]
     ], [
