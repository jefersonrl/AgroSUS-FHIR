  <description value="Workflow de suporte à decisão: classifica o resultado da colinesterase, define a periodicidade do monitoramento biológico e avalia gatilhos de alerta independentes (sintomas, produto sem EPI adequado, histórico de intoxicação). Apoia — não substitui — o julgamento clínico do profissional assistencial da UBS."/>
  <jurisdiction>
    <coding>
      <system value="urn:iso:std:iso:3166"/>
      <code value="BR"/>
      <display value="Brazil"/>
    </coding>
  </jurisdiction>
  <library value="https://jefersonrl.github.io/AgroSUS-FHIR/Library/AgroSUSIntoxicacaoLogic"/>
  <action>
    <title value="Obter valor basal e resultado da colinesterase"/>
    <description value="Determinar a atividade basal (pré-ocupacional) na admissão; calcular o percentual de inibição do resultado atual em relação ao basal. Registrado via ServiceRequest/AgroSUSSolicitacaoExame e Observation/AgroSUSResultadoLaboratorial."/>
  </action>
  <action>
    <title value="Classificar o resultado da colinesterase"/>
    <description value="Classifica o percentual de inibição conforme o tipo de amostra. REVISAR fonte: NR-7 Quadro I; Nota Informativa 16/2019."/>
    <action>
      <title value="Normal — colinesterase plasmática (inibição &lt;= 50%) ou sangue total (inibição &lt;= 25%)"/>
      <condition>
        <kind value="applicability"/>
        <expression>
          <language value="text/fhirpath"/>
          <expression value="%inibicaoPlasmatica &lt;= 50 or %inibicaoSangueTotal &lt;= 25"/>
        </expression>
      </condition>
    </action>
    <action>
      <title value="Precaução — redução de 20% a 50%/25% (não atinge o IBMP)"/>
      <condition>
        <kind value="applicability"/>
        <expression>
          <language value="text/fhirpath"/>
          <expression value="%inibicaoPlasmatica &gt;= 20 and %inibicaoPlasmatica &lt;= 50"/>
        </expression>
      </condition>
    </action>
    <action>
      <title value="Alterado — excede o Índice Biológico Máximo Permitido (IBMP)"/>
      <condition>
        <kind value="applicability"/>
        <expression>
          <language value="text/fhirpath"/>
          <expression value="%inibicaoPlasmatica &gt; 50 or %inibicaoSangueTotal &gt; 25"/>
        </expression>
      </condition>
    </action>
  </action>
  <action>
    <title value="Definir periodicidade do monitoramento biológico"/>
    <description value="Periodicidade mínima semestral (NR-7 7.4.2.1), com gatilhos adicionais independentes da rotina."/>
    <action>
      <title value="Rotina — no mínimo a cada 6 meses"/>
    </action>
    <action>
      <title value="Gatilho adicional — admissional, retorno de afastamento &gt; 30 dias, mudança de função, sintomático, após surto/bloqueio de aplicação, ou retestagem pós-resultado alterado"/>
    </action>
  </action>
  <action>
    <title value="Conduta frente a resultado alterado"/>
    <description value="Afastar do contato com o agrotóxico por 30 dias; encaminhar para avaliação clínica e laboratorial; repetir exame em 30 dias; investigar outras causas antes de concluir pela exposição ocupacional. Registrado via CarePlan/AgroSUSPlanoAcompanhamento."/>
    <condition>
      <kind value="applicability"/>
      <expression>
        <language value="text/fhirpath"/>
        <expression value="%inibicaoPlasmatica &gt; 50 or %inibicaoSangueTotal &gt; 25"/>
      </expression>
    </condition>
  </action>
  <action>
    <title value="Avaliar gatilhos de alerta independentes"/>
    <description value="Gatilhos discretos que não compõem escore (ver ADR-0002). Qualquer gatilho presente prioriza avaliação clínica na UBS."/>
    <action>
      <title value="Sintoma agudo compatível com intoxicação (Seção 13 da anamnese)"/>
    </action>
    <action>
      <title value="Manuseio de defensivo categoria toxicológica 1 ou 2 sem EPI adequado registrado (Seções 6 e 9)"/>
    </action>
    <action>
      <title value="Histórico de intoxicação aguda prévia (Seção 14)"/>
    </action>
    <action>
      <title value="Colinesterase alterada ou em precaução (Ação 2)"/>
    </action>
  </action>
  <action>
    <title value="Registrar e manter o histórico"/>
    <description value="Manter registro de exames, afastamentos e condutas por, no mínimo, 20 anos após o desligamento do trabalhador (NR-7 7.4.5.1). Registrado via Provenance/AgroSUSProvenance."/>
  </action>
</PlanDefinition>