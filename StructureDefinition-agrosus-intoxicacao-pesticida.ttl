         fhir:ElementDefinition.constraint.key [ fhir:value "con-3" ] ;
         fhir:ElementDefinition.constraint.severity [ fhir:value "warning" ] ;
         fhir:ElementDefinition.constraint.human [ fhir:value "Condition.clinicalStatus SHALL be present if verificationStatus is not entered-in-error and category is problem-list-item" ] ;
         fhir:ElementDefinition.constraint.expression [ fhir:value "clinicalStatus.exists() or verificationStatus.coding.where(system='http://terminology.hl7.org/CodeSystem/condition-ver-status' and code = 'entered-in-error').exists() or category.select($this='problem-list-item').empty()" ] ;
         fhir:ElementDefinition.constraint.xpath [ fhir:value "exists(f:clinicalStatus) or exists(f:verificationStatus/f:coding/f:code/@value='entered-in-error') or not(exists(category[@value='problem-list-item']))" ] ;
         fhir:ElementDefinition.constraint.source [
           fhir:value "http://hl7.org/fhir/StructureDefinition/Condition" ;
           fhir:link <http://hl7.org/fhir/StructureDefinition/Condition>
